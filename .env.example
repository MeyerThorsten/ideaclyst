# IdeaClyst configuration. Copy to .env.local and adjust.
# No secrets required — the CLIs authenticate via their own local sessions.

# Agent backend: "mock" (default, no real CLI calls) or "cli" (real claude/codex).
IDEACLYST_AGENT_MODE=mock

# Binaries for CLI mode (override if not on PATH).
IDEACLYST_CLAUDE_BIN=claude
IDEACLYST_CODEX_BIN=codex

# Optional concrete Claude model (e.g. "opus", "sonnet"). Empty or "default"
# defers to the claude CLI's own default model.
IDEACLYST_CLAUDE_MODEL=

# Optional concrete Codex model. Empty or "default" defers to ~/.codex/config.toml.
IDEACLYST_CODEX_MODEL=

# Per-agent-call timeout in milliseconds.
IDEACLYST_AGENT_TIMEOUT_MS=180000

# Where run packets are stored on disk.
IDEACLYST_DATA_DIR=.ideaclyst

# --- Web research (surfagent-powered, best-effort) ---
# Research follows IDEACLYST_AGENT_MODE by default (cli→live headless Chrome,
# mock→offline). Override to force mock research while agents run live:
IDEACLYST_RESEARCH_MODE=
# Search engine for the live path: duckduckgo (default, friendliest) | bing | google
IDEACLYST_RESEARCH_ENGINE=duckduckgo
# Strict mode: when "1", the research layer NEVER shows fabricated/offline ("mock")
# content — if live data can't be gathered it shows a clear notice instead. Pair
# with IDEACLYST_RESEARCH_MODE=live (and Chrome installed) to only ever see real data.
IDEACLYST_RESEARCH_STRICT=
# Optional Chrome/Chromium path override (auto-detected otherwise).
IDEACLYST_CHROME_BIN=
# Optional user-agent override for headless Chrome. Defaults to a normal desktop
# Chrome UA so search engines don't serve a bot challenge to "HeadlessChrome".
IDEACLYST_RESEARCH_USER_AGENT=
IDEACLYST_RESEARCH_CDP_PORT=9222
IDEACLYST_RESEARCH_CDP_HOST=localhost
# Budgets / caps for the live path.
IDEACLYST_RESEARCH_TIMEOUT_MS=20000     # per page recon
IDEACLYST_RESEARCH_BUDGET_MS=60000      # whole research step
IDEACLYST_RESEARCH_MAX_RESULTS=6
IDEACLYST_RESEARCH_MAX_SOURCES=3
IDEACLYST_RESEARCH_IDLE_MS=120000       # reap idle headless Chrome

# Optional keyword snapshot adapter. Keep empty for deterministic offline estimates.
# JSON shape: [{"keyword":"ai onboarding analytics","volume":"1.2K","growth":"+48%","competition":"medium","relevance":4}]
IDEACLYST_KEYWORD_SNAPSHOT_JSON=
IDEACLYST_KEYWORD_SNAPSHOT_FRESHNESS=
